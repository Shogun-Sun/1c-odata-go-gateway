# --- Настройки пользователя (для правильных прав доступа к файлам на хосте) ---
UID=1000
GID=1000

# --- Настройки публикации 1С ---
# Имя виртуального каталога (будет доступно по адресу: http://localhost:8080/<WS_DIR>/)
WS_DIR=

# Путь к директории с базой данных внутри контейнера
BASE_DIR=/base

# --- Системные настройки ---
# Имя системного пользователя веб-сервера (в Alt Linux p11 это apache2)
WEB_USER=apache2

# Путь к папке с базой данных на ВАШЕМ компьютере (относительно docker-compose.yml)
HOST_BASE_PATH=

# --- Настройки API (Go) ---
# URL для подключения к OData сервису 1С
ODATA_URL=http://1c-server/booking/odata/standard.odata/
ODATA_USERNAME=administrator
ODATA_PASSWORD=

# Порты для API
# Порт, который будет доступен на хосте
EXTERNAL_GO_SERVER_PORT=4000
# Порт, который слушает приложение
GO_SERVER_PORT=4000